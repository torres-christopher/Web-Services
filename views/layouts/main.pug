doctype html
html(lang='cs')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')

    //- SEO
    title= title ? `${title} — ${siteName}` : siteName
    meta(name='description' content=metaDescription || '')
    if canonicalPath
      link(rel='canonical' href=`${siteUrl}${canonicalPath}`)

    //- Structured data
    if jsonLd
      script(type='application/ld+json')
        | !{JSON.stringify(jsonLd)}

    //- Open Graph
    meta(property='og:type' content='website')
    meta(property='og:title' content=ogTitle || title)
    meta(property='og:description' content=ogDescription || metaDescription)
    meta(property='og:url' content=`${siteUrl}${canonicalPath || ''}`)
    meta(property='og:site_name' content=siteName)
    meta(property='og:image' content=ogImage || `${siteUrl}/images/og-default.png`)

    //- Favicon
    link(rel='icon' type='image/ico' href='/images/favicon.ico')

    //- Styles
    link(rel='stylesheet' href='/css/main.css')

    //- Google Analytics
    if gaMeasurementId
      script(async src=`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`)
      script.
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '#{gaMeasurementId}', { anonymize_ip: true });

  body

    header.site-header
      div(class=wideLayout ? 'container-wide' : 'container')
        .site-header__inner
          a.site-logo(href='/')
            span.site-logo__mark WS
            span.site-logo__name= siteName
          include ../partials/nav
          .site-header__cta
            a.btn.btn--ghost-inverse.btn--sm(href='/nastroje') Všechny nástroje
          button.nav-toggle(aria-label='Otevřít menu' aria-expanded='false')
            span
            span
            span

    main.site-main
      block content

    footer.site-footer
      div(class=wideLayout ? 'container-wide' : 'container')
        .site-footer__grid
          .site-footer__brand
            a.site-logo.site-logo--footer(href='/')
              span.site-logo__mark WS
              span.site-logo__name= siteName
            p.site-footer__tagline Bezplatné české online nástroje
          .site-footer__links
            h4.site-footer__heading Kategorie
            ul
              li: a(href='/nastroje#text') Textové nástroje
              li: a(href='/nastroje#dev') Pro vývojáře
              li: a(href='/nastroje#czech') Česká data
              li: a(href='/nastroje#zdravi') Zdraví & fitness
              li: a(href='/nastroje#prevodnik') Převodníky
          .site-footer__links
            h4.site-footer__heading Informace
            ul
              li: a(href='/faq') Časté dotazy
              li: a(href='/ochrana-osobnich-udaju') Ochrana soukromí
              li: a(href='/podminky-pouziti') Podmínky použití
              li: a(href='/kontakt') Kontakt
        .site-footer__bottom
          p &copy; #{currentYear} #{siteName}. Všechna práva vyhrazena.

    //- AdSense
    if adsenseClientId
      script(async src=`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}` crossorigin='anonymous')

    script(src='/js/main.js')
    block scripts
