doctype html
html(lang='cs')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')

    //- SEO
    title= title ? `${title} — ${siteName}` : siteName
    meta(name='description' content=metaDescription || '')
    if canonicalPath
      link(rel='canonical' href=`${siteUrl}${canonicalPath}`)

    //- Structured data
    if jsonLd
      script(type='application/ld+json')
        | !{JSON.stringify(jsonLd)}

    //- Open Graph
    meta(property='og:type' content='website')
    meta(property='og:title' content=ogTitle || title)
    meta(property='og:description' content=ogDescription || metaDescription)
    meta(property='og:url' content=`${siteUrl}${canonicalPath || ''}`)
    meta(property='og:site_name' content=siteName)
    meta(property='og:image' content=ogImage || `${siteUrl}/images/og-default.png`)

    //- Favicon
    link(rel='icon' type='image/ico' href='/images/favicon.ico')

    //- Styles
    link(rel='stylesheet' href='/css/main.css')

    //- Consent Mode v2 defaults, fires before GTM loads
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500
      });

    //- Google Tag Manager --> loads immediately, consent controls what fires
    if gtmContainerId
      script.
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','!{gtmContainerId}');

  body  
    //- GTM noscript fallback — only rendered when container ID is set
    if gtmContainerId
      noscript
        iframe(src=`https://www.googletagmanager.com/ns.html?id=${gtmContainerId}` height='0' width='0' style='display:none;visibility:hidden')

    header.site-header
      div(class=wideLayout ? 'container-wide' : 'container')
        .site-header__inner
          a.site-logo(href='/')
            span.site-logo__mark TH
            span.site-logo__name= siteName
          include ../partials/nav
          .site-header__cta
            a.btn.btn--ghost-inverse.btn--sm(href='/vsechny-nastroje') Všechny nástroje
          button.nav-toggle(aria-label='Otevřít menu' aria-expanded='false')
            span
            span
            span

    main.site-main
      block content

    footer.site-footer
      div(class=wideLayout ? 'container-wide' : 'container')
        .site-footer__grid
          .site-footer__brand
            a.site-logo.site-logo--footer(href='/')
              span.site-logo__mark TH
              span.site-logo__name= siteName
            p.site-footer__tagline Bezplatné české online nástroje
          .site-footer__links
            h4.site-footer__heading Kategorie
            ul
              li: a(href='/textove-nastroje') Textové nástroje
              li: a(href='/vyvojarske-nastroje') Pro vývojáře
              li: a(href='/ceske-nastroje') Česká data
              li: a(href='/zdravotni-nastroje') Zdraví & fitness
          .site-footer__links
            h4.site-footer__heading Informace
            ul
              li: a(href='/faq') Časté dotazy
              li: a(href='/ochrana-osobnich-udaju') Ochrana soukromí
              li: a(href='/podminky-pouziti') Podmínky použití
              li: a(href='/kontakt') Kontakt
        .site-footer__bottom
          p &copy; #{currentYear} #{siteName}. Všechna práva vyhrazena.

    //- AdSense
    if adsenseClientId
      script(async src=`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}` crossorigin='anonymous')

    //- Cookie banner
    div.cookie-banner(id='cookieBanner' role='dialog' aria-label='Souhlas s cookies')
      .cookie-banner__inner
        p.cookie-banner__text
          | Používáme analytické cookies (Google Analytics) pro zlepšení webu.
          | Více informací v&nbsp;
          a(href='/ochrana-osobnich-udaju') zásadách ochrany soukromí
          | .
        .cookie-banner__actions
          button.btn.btn--primary.btn--sm(id='cookieAccept') Přijmout
          button.btn.btn--ghost-inverse.btn--sm(id='cookieDecline') Odmítnout
    script(src='/js/main.js')
    block scripts
