extends ../../../layouts/main

block content
  //- Tool header — breadcrumb + title
  include ../../../partials/tool-header

  .tool-layout
    .container
      .tool-layout__inner

        //- ── Main column ──────────────────────────────────────
        .tool-layout__main

          //- Error message
          if errorMessage
            .alert.alert--error(role='alert')
              p= errorMessage

          //- Input form
          form(method='POST' action='/zdravotni-nastroje/bmi-kalkulacka')
            .form-row
              .form-group
                label.form-label(for='height') Výška (cm)
                input.form-input(
                  type='number'
                  id='height'
                  name='height'
                  min='1'
                  max='300'
                  placeholder='např. 175'
                  value=height || ''
                  autocomplete='off'
                )
              .form-group
                label.form-label(for='weight') Váha (kg)
                input.form-input(
                  type='number'
                  id='weight'
                  name='weight'
                  min='1'
                  max='1000'
                  placeholder='např. 70'
                  value=weight || ''
                  autocomplete='off'
                )
            button.btn.btn--primary(type='submit') Spočítat BMI

          //- Result
          if result
            .tool-result
              .tool-result__header
                span.tool-result__heading Váš výsledek
              .tool-result__content
                .stat-grid
                  .stat-card
                    .stat-card__value= result.bmiValue.toFixed(1)
                    .stat-card__label BMI
                  .stat-card
                    .stat-card__value= height
                    .stat-card__label Výška (cm)
                  .stat-card
                    .stat-card__value= weight
                    .stat-card__label Váha (kg)
                .bmi-classification(class=`bmi-classification--${result.bmiClassification}`)
                  p.bmi-classification__label
                    | Klasifikace:&nbsp;
                    strong= label
                .bmi-scale
                  .bmi-scale__bar
                    .bmi-scale__segment.bmi-scale__segment--underweight
                      span.bmi-scale__segment-label Podváha
                      span.bmi-scale__segment-range &lt; 18.5
                    .bmi-scale__segment.bmi-scale__segment--normal
                      span.bmi-scale__segment-label Normální
                      span.bmi-scale__segment-range 18.5–25
                    .bmi-scale__segment.bmi-scale__segment--overweight
                      span.bmi-scale__segment-label Nadváha
                      span.bmi-scale__segment-range 25–30
                    .bmi-scale__segment.bmi-scale__segment--obese-1
                      span.bmi-scale__segment-label Obezita I
                      span.bmi-scale__segment-range 30–35
                    .bmi-scale__segment.bmi-scale__segment--obese-2
                      span.bmi-scale__segment-label Obezita II
                      span.bmi-scale__segment-range 35–40
                    .bmi-scale__segment.bmi-scale__segment--obese-3
                      span.bmi-scale__segment-label Obezita III
                      span.bmi-scale__segment-range &gt; 40
                  .bmi-scale__track
                    .bmi-scale__marker(style=`left: ${markerPosition}%`)

          //- Tool FAQ
          include ../../../partials/tool-faq
          //- Related tools
          include ../../../partials/tool-related

        //- ── Sidebar ──────────────────────────────────────────
        .tool-layout__sidebar

          //- Ad slot
          include ../../../partials/ad-slot

          .sidebar-info
            h3.sidebar-info__title O nástroji
            p.sidebar-info__text
              | BMI (Body Mass Index) je jednoduchý ukazatel poměru váhy a výšky.
              | Používá se jako orientační měřítko k posouzení zdravotního rizika spojeného s váhou člověka.
              | Určuje, zda má jedinec podváhu, normální váhu, nadváhu či obezitu.
            ul.sidebar-info__list
              li Data se nikam neukládají
              li Výsledky předpokládají věk 20 let a výše
              li BMI není absolutní ukazatel zdraví
