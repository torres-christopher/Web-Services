extends ../../../layouts/main

block content

  //- Tool header — breadcrumb + title
  include ../../../partials/tool-header

  .tool-layout
    .container
      .tool-layout__inner

        //- ── Main column ──────────────────────────────────────
        .tool-layout__main

          //- Error message
          if errorState && errorMessage
            .alert.alert--error(role='alert')
              p= errorMessage

          //- Input form
          form(method='POST' action='/text/pocet-znaku')
            .form-group
              textarea.form-textarea.form-textarea--large(
                id='text'
                name='text'
                placeholder='Sem vložte nebo napište svůj text...'
                autocomplete='off'
                spellcheck='true'
              )= text || ''

              //- Live stats — shown immediately via JS, hidden until JS runs
              .pocet-znaku-live(id='liveStats' aria-live='polite')
                .stat-grid
                  .stat-card
                    p.stat-card__value(id='stat-raw')= result ? result.textLengthRaw : 0
                    p.stat-card__label Znaků celkem
                  .stat-card
                    p.stat-card__value(id='stat-nospace')= result ? result.textLengthNoSpace : 0
                    p.stat-card__label Znaků bez mezer
                  .stat-card
                    p.stat-card__value(id='stat-words')= result ? result.wordCount : 0
                    p.stat-card__label Slov
                  .stat-card
                    p.stat-card__value(id='stat-sentences')= result ? result.sentenceCount : 0
                    p.stat-card__label Vět
                  .stat-card
                    p.stat-card__value(id='stat-lines')= result ? result.lineCount : 0
                    p.stat-card__label Řádků
                  .stat-card
                    p.stat-card__value(id='stat-ns')= result ? result.nsCount.toFixed(2) : '0.00'
                    p.stat-card__label Normostran
                  .stat-card
                    p.stat-card__value(id='stat-reading')= result ? result.readingTime : 0
                    p.stat-card__label Minut čtení

              button.btn.btn--primary(type='submit') Spočítat
          

          //- Tool FAQ
          include ../../../partials/tool-faq

          //- Related tools
          include ../../../partials/tool-related

        //- ── Sidebar ──────────────────────────────────────────
        .tool-layout__sidebar

          //- Ad slot
          include ../../../partials/ad-slot

          //- About this tool
          .sidebar-info
            h3.sidebar-info__title O nástroji
            p.sidebar-info__text
              | Počítadlo znaků zobrazuje přesný počet znaků, slov, vět,
              | řádků a normostran. Výsledky se aktualizují v reálném čase
              | při psaní.
            ul.sidebar-info__list
              li Výsledky se aktualizují živě při psaní
              li Text se nikam neukládá
              li Vhodné pro češtinu i běžné latinkové texty
              li Odhad vět a doby čtení je orientační
              li Funguje i bez JavaScriptu přes odeslání formuláře

  //- Page script for live counting
  script(src='/js/tools/pocet-znaku.js' defer)
